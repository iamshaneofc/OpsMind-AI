# Copy to ".env" and fill in real values (never commit .env).
# Run: copy .env.example .env   (Windows)   or   cp .env.example .env

# --- Required ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Set to true to skip Supabase manual order allocation reads (ERP-only derivation).
# SKIP_ERP_MANUAL_ALLOCATION=false

# Set to true to skip writing derived status snapshots to Supabase (Gap B journal).
# SKIP_ERP_STATUS_JOURNAL=false

# Set to true to skip persisting ETA/next-update cache rows (`erp_order_predictions`, Gap C+D).
# SKIP_ERP_PREDICTIONS_CACHE=false

# Days stuck in AWAITING_FACTORY (vs order voucher age) before Lane A recommends escalate next_action.
# FACTORY_STALE_ESCALATION_DAYS=14

OPENAI_API_KEY=sk-your-openai-key

# --- Optional: npm run test:chat-erp (hits real /api/chat) ---
# CHAT_TEST_PASSWORD=your_test_user_password
# CHAT_TEST_EMAIL=distributor@opsmindchemicals.com
# CHAT_API_BEARER_TOKEN=  # or paste a JWT instead of password sign-in
# APP_BASE_URL=http://localhost:3000
# LOG_ERP_SQL=1

# --- Optional: ERP SQL Server (dashboard orders/inventory/chat tools) ---
# USE_SQL_SERVER_DATA=false
# SQL_SERVER_HOST=
# SQL_SERVER_PORT=1433
# SQL_SERVER_USER=
# SQL_SERVER_PASSWORD=
# SQL_SERVER_DATABASE=
# SQL_SERVER_ENCRYPT=true
# SQL_SERVER_TRUST_SERVER_CERTIFICATE=true
# ERP_LOCAL_HUB_LOCATION_ID=1   # Super-admin "local warehouse" chat shortcut (Krisshna+Viraj scope); default 1
# ERP_CENTRAL_WAREHOUSE_LOCATION_ID=6   # Optional override; app defaults to 6 (BhiwandiDepot) for "central warehouse" chat shortcut
