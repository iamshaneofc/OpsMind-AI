{
  "name": "opsmind-operations-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:clean": "node -e \"const fs=require('fs'); if(fs.existsSync('.next')) fs.rmSync('.next',{recursive:true,force:true});\" && next dev -p 3001",
    "dev:fresh": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});}catch(e){}\" && next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed:demo": "node scripts/seed-demo.mjs",
    "test:dataflow": "node scripts/test-dataflow.mjs",
    "import:invoices": "node scripts/import-invoices.mjs",
    "test:system": "node scripts/test-system-comprehensive.mjs",
    "test:auth": "node scripts/test-authentication-rls.mjs",
    "test:all": "npm run test:system && npm run test:auth",
    "test:sql-server": "node scripts/test-sql-server.mjs",
    "verify:erp-db": "node scripts/verify-erp-database-snapshot.mjs",
    "test:p1": "vitest run src/p1-matrix-tool-verification.test.ts",
    "test:lane-a": "vitest run",
    "test:lane-a:watch": "vitest",
    "test:chat-erp": "node scripts/run-chat-erp-query-tests.mjs",
    "verify:openai": "node scripts/verify-openai.mjs",
    "local:check": "node scripts/check-local-env.mjs",
    "supabase:list-companies": "node scripts/list-supabase-companies.mjs",
    "supabase:plan-warehouse-updates": "node scripts/generate-company-warehouse-updates.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^5.5.6",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "next": "14.2.5",
    "openai": "^6.26.0",
    "pg": "^8.21.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "prisma": "^7.8.0",
    "supabase": "^2.104.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
